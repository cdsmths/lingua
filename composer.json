{
    "name": "cyberwolfstudio/lingua",
    "description": "Add your Laravel language translations to your asset pipeline for use in Javascript packages like Vue or React.",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "secondman",
            "email": "secondman@jetstreamlabs.com"
        },
        {
            "name": "cyberwolfstudio",
            "email": "hello@cyberwolfstudio.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "CyberWolfStudio\\Lingua\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CyberWolfStudio\\Lingua\\LinguaServiceProvider"
            ]
        }
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "orchestra/pest-plugin-testbench": "^4.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
